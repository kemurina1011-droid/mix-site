<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Kemurina_BGM | 歌ってみたMIX受付</title>
    <meta
      name="description"
      content="歌を前に出しつつ、オケに自然に馴染む歌ってみたMIXをご案内しています。"
    />

    <style>
      :root {
        --bg: #151517;
        --bg-soft: #1d1d21;
        --panel: rgba(255, 255, 255, 0.05);
        --line: rgba(255, 255, 255, 0.08);
        --text: #f3f3f4;
        --muted: #b8b8be;
        --accent: #dbdde2;
        --accent-hover: #f0f1f3;
        --accent-dark: #111214;
        --max-width: 1120px;
        --success-bg: rgba(70, 180, 120, 0.12);
        --success-line: rgba(70, 180, 120, 0.35);
        --error-bg: rgba(220, 90, 90, 0.12);
        --error-line: rgba(220, 90, 90, 0.35);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", "Hiragino Sans",
          "Hiragino Kaku Gothic ProN", "Yu Gothic", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at 20% 0%, rgba(255,255,255,0.05), transparent 28%),
          radial-gradient(circle at 80% 20%, rgba(255,255,255,0.035), transparent 22%),
          linear-gradient(180deg, #111214 0%, #18191c 45%, #1f2024 100%);
        line-height: 1.75;
        letter-spacing: 0.01em;
        overflow-x: hidden;
      }

      body::before {
        content: "";
        position: fixed;
        inset: -10% -10% auto -10%;
        height: 60vh;
        background:
          radial-gradient(circle at 30% 40%, rgba(255,255,255,0.04), transparent 22%),
          radial-gradient(circle at 70% 30%, rgba(255,255,255,0.03), transparent 18%);
        filter: blur(40px);
        pointer-events: none;
        z-index: 0;
        animation: ambientShift 14s ease-in-out infinite alternate;
      }

      @keyframes ambientShift {
        0% {
          transform: translate3d(0, 0, 0) scale(1);
          opacity: 0.9;
        }
        100% {
          transform: translate3d(0, 18px, 0) scale(1.03);
          opacity: 1;
        }
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      .container {
        width: min(var(--max-width), calc(100% - 32px));
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 30;
        backdrop-filter: blur(14px);
        background: rgba(20, 20, 22, 0.72);
        border-bottom: 1px solid rgba(255, 255, 255, 0.05);
      }

      .header-inner {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 20px;
      }

      .brand-wrap {
        display: flex;
        align-items: center;
        gap: 12px;
        min-width: 0;
      }

      .brand {
        font-size: 20px;
        font-weight: 700;
        letter-spacing: 0.05em;
        line-height: 1;
        white-space: nowrap;
      }

      .header-nav {
        display: flex;
        gap: 18px;
        flex-wrap: wrap;
      }

      .header-nav a {
        font-size: 14px;
        color: var(--muted);
        transition: color 0.2s ease;
      }

      .header-nav a:hover {
        color: var(--text);
      }

      .hero {
        padding: 112px 0 92px;
      }

      .hero-inner {
        max-width: 980px;
        animation: heroScaleIn 1.2s cubic-bezier(0.22, 1, 0.36, 1) both;
        transform-origin: center top;
      }

      @keyframes heroScaleIn {
        0% {
          opacity: 0;
          transform: translateY(30px) scale(1.02);
        }
        100% {
          opacity: 1;
          transform: translateY(0) scale(1);
        }
      }

      .hero-animate {
        opacity: 0;
        transform: translateY(24px);
        animation: heroReveal 1s cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .hero-animate.delay-2 {
        animation-delay: 0.18s;
      }

      .hero-animate.delay-3 {
        animation-delay: 0.38s;
      }

      .hero-animate.delay-4 {
        animation-delay: 0.58s;
      }

      @keyframes heroReveal {
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      .hero-title-wrap {
        position: relative;
        display: inline-block;
        max-width: 100%;
      }

      .hero-title-wrap::after {
        content: "";
        position: absolute;
        left: 7%;
        right: 7%;
        bottom: -10px;
        height: 34px;
        background: radial-gradient(
          ellipse at center,
          rgba(255,255,255,0.12) 0%,
          rgba(255,255,255,0.05) 38%,
          transparent 78%
        );
        filter: blur(18px);
        pointer-events: none;
        opacity: 0.9;
      }

      .hero-title {
        position: relative;
        z-index: 1;
        margin: 22px 0 18px;
        font-size: clamp(24px, 4.3vw, 64px);
        line-height: 1.08;
        letter-spacing: -0.05em;
        white-space: nowrap;
        color: transparent;
        background: linear-gradient(
          180deg,
          rgba(255,255,255,0.98) 0%,
          rgba(236,236,240,0.9) 42%,
          rgba(186,186,194,0.72) 100%
        );
        -webkit-background-clip: text;
        background-clip: text;
        text-shadow:
          0 0 12px rgba(255,255,255,0.06),
          0 10px 28px rgba(255,255,255,0.04);
        filter: saturate(0.88);
      }

      .hero-lead {
        max-width: 820px;
        margin: 0;
        font-size: 18px;
        color: var(--muted);
      }

      .hero-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 30px;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 50px;
        padding: 0 22px;
        border-radius: 999px;
        font-weight: 700;
        transition: transform 0.25s ease, background 0.25s ease, border-color 0.25s ease;
        border: 1px solid transparent;
        font: inherit;
        cursor: pointer;
      }

      .button-primary {
        background: var(--accent);
        color: var(--accent-dark);
      }

      .button-primary:hover {
        transform: translateY(-2px) scale(1.01);
        background: var(--accent-hover);
      }

      .button-secondary {
        background: rgba(255, 255, 255, 0.03);
        border-color: var(--line);
        color: var(--text);
      }

      .button-secondary:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.07);
      }

      .inline-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--text);
        border-bottom: 1px solid rgba(255,255,255,0.2);
        padding-bottom: 1px;
      }

      .inline-link:hover {
        color: var(--accent-hover);
        border-bottom-color: rgba(255,255,255,0.45);
      }

      section {
        padding: 88px 0;
      }

      .section-head {
        margin-bottom: 26px;
      }

      .section-title {
        margin: 0 0 10px;
        font-size: clamp(28px, 4vw, 44px);
        line-height: 1.15;
        letter-spacing: -0.03em;
      }

      .section-lead {
        margin: 0;
        color: var(--muted);
        max-width: 760px;
      }

      .grid-2 {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .grid-3 {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 16px;
      }

      .card,
      .price-card,
      .cta,
      .works-card,
      .discount-card,
      .terms-card,
      .payment-card,
      .recommend-line,
      .preview-card,
      .delivery-card {
        transition:
          transform 0.5s cubic-bezier(0.22, 1, 0.36, 1),
          background 0.25s ease,
          border-color 0.25s ease,
          opacity 1s cubic-bezier(0.22, 1, 0.36, 1);
      }

      .card,
      .discount-card,
      .terms-card,
      .payment-card,
      .recommend-line,
      .preview-card,
      .delivery-card {
        padding: 24px;
        border-radius: 28px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.06),
          rgba(255, 255, 255, 0.03)
        );
        border: 1px solid var(--line);
      }

      .card:hover,
      .discount-card:hover,
      .terms-card:hover,
      .payment-card:hover,
      .recommend-line:hover,
      .preview-card:hover,
      .delivery-card:hover {
        transform: translateY(-6px);
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.075),
          rgba(255, 255, 255, 0.04)
        );
      }

      .card h3,
      .discount-card h3,
      .terms-card h3,
      .payment-card h3,
      .preview-card h3,
      .delivery-card h3 {
        margin: 0 0 10px;
        font-size: 20px;
      }

      .card p,
      .card li,
      .discount-card p,
      .discount-card li,
      .terms-card p,
      .terms-card li,
      .payment-card p,
      .payment-card li,
      .preview-card p,
      .delivery-card p,
      .delivery-card li {
        color: var(--muted);
      }

      .card ul,
      .discount-card ul,
      .terms-card ul,
      .payment-card ul,
      .delivery-card ul {
        margin: 10px 0 0;
        padding-left: 18px;
      }

      .preview-card {
        overflow: hidden;
      }

      .preview-video {
        position: relative;
        width: 100%;
        padding-top: 56.25%;
        margin-top: 14px;
        border-radius: 20px;
        overflow: hidden;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
      }

      .preview-video iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }

      .recommend-line {
        padding: 18px 20px;
      }

      .recommend-label {
        display: block;
        margin-bottom: 10px;
        font-size: 15px;
        color: var(--text);
        font-weight: 700;
      }

      .recommend-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
      }

      .recommend-chip,
      .payment-chip,
      .works-tab {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 40px;
        padding: 0 14px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(255,255,255,0.08);
        color: var(--text);
        font-size: 14px;
      }

      .discount-grid {
        display: grid;
        grid-template-columns: repeat(5, minmax(0, 1fr));
        gap: 16px;
        margin-bottom: 16px;
      }

      .discount-card .discount-name {
        display: block;
        margin-bottom: 8px;
        font-size: 16px;
        color: var(--text);
        font-weight: 700;
      }

      .discount-card .discount-value {
        display: block;
        margin-bottom: 10px;
        font-size: 28px;
        line-height: 1.1;
        font-weight: 800;
        letter-spacing: -0.03em;
      }

      .discount-card p {
        margin: 0;
        font-size: 14px;
        line-height: 1.7;
      }

      .discount-footer-link {
        margin-top: 14px;
        color: var(--muted);
      }

      .price-stack {
        display: grid;
        gap: 14px;
      }

      .price-card {
        padding: 24px;
        border-radius: 26px;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.07),
          rgba(255, 255, 255, 0.04)
        );
        border: 1px solid var(--line);
      }

      .price-card:hover {
        transform: translateY(-6px);
      }

      .price-label {
        color: var(--muted);
        font-size: 14px;
        margin-bottom: 8px;
      }

      .price-value {
        font-size: 32px;
        font-weight: 800;
        line-height: 1.15;
        letter-spacing: -0.03em;
      }

      .price-subtext {
        margin-top: 10px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
      }

      .price-highlight {
        margin-top: 16px;
        padding: 18px 20px;
        border-radius: 22px;
        background: linear-gradient(
          180deg,
          rgba(219, 221, 226, 0.14),
          rgba(255, 255, 255, 0.05)
        );
        border: 1px solid rgba(219, 221, 226, 0.18);
      }

      .price-highlight strong {
        display: block;
        margin-bottom: 6px;
        font-size: 16px;
      }

      .price-highlight p {
        margin: 0;
        color: var(--muted);
      }

      .section-cta {
        margin-top: 18px;
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .sub {
        color: var(--muted);
        font-size: 13px;
        margin-top: 8px;
      }

      .terms-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
        margin-top: 14px;
      }

      .terms-block {
        padding: 18px;
        border-radius: 20px;
        background: rgba(255,255,255,0.03);
        border: 1px solid rgba(255,255,255,0.06);
      }

      .terms-block h4 {
        margin: 0 0 10px;
        font-size: 16px;
        color: var(--text);
      }

      .terms-block ul {
        margin: 0;
        padding-left: 18px;
      }

      .payment-list {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 14px;
      }

      .payment-note {
        margin-top: 14px;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.8;
      }

      .delivery-card ul {
        margin-top: 12px;
      }

      .works-tabs {
        display: flex;
        gap: 10px;
        flex-wrap: wrap;
        margin-bottom: 16px;
      }

      .works-tab {
        cursor: pointer;
        transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
      }

      .works-tab:hover {
        transform: translateY(-1px);
        background: rgba(255, 255, 255, 0.08);
      }

      .works-tab.is-active {
        background: var(--accent);
        color: var(--accent-dark);
        border-color: transparent;
      }

      .works-panel {
        display: none;
      }

      .works-panel.is-active {
        display: block;
      }

      .works-scroll-wrap {
        position: relative;
      }

      .works-controls {
        display: flex;
        justify-content: flex-end;
        gap: 10px;
        margin-bottom: 14px;
      }

      .works-nav-button {
        width: 44px;
        height: 44px;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
        font-size: 18px;
        cursor: pointer;
        transition: transform 0.2s ease, background 0.25s ease;
      }

      .works-nav-button:hover {
        transform: translateY(-2px);
        background: rgba(255, 255, 255, 0.08);
      }

      .works-scroll {
        display: grid;
        grid-auto-flow: column;
        gap: 16px;
        overflow-x: auto;
        padding-bottom: 8px;
        scroll-snap-type: x mandatory;
        -webkit-overflow-scrolling: touch;
        scroll-behavior: smooth;
      }

      .works-scroll.full-scroll {
        grid-auto-columns: min(420px, 85vw);
      }

      .works-scroll.short-scroll {
        grid-auto-columns: min(260px, 72vw);
      }

      .works-scroll::-webkit-scrollbar {
        height: 10px;
      }

      .works-scroll::-webkit-scrollbar-track {
        background: rgba(255, 255, 255, 0.04);
        border-radius: 999px;
      }

      .works-scroll::-webkit-scrollbar-thumb {
        background: rgba(255, 255, 255, 0.14);
        border-radius: 999px;
      }

      .works-scroll::-webkit-scrollbar-thumb:hover {
        background: rgba(255, 255, 255, 0.22);
      }

      .works-card {
        scroll-snap-align: start;
        border-radius: 28px;
        overflow: hidden;
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.06),
          rgba(255, 255, 255, 0.03)
        );
        border: 1px solid var(--line);
      }

      .works-card:hover {
        transform: translateY(-6px);
        background: linear-gradient(
          180deg,
          rgba(255, 255, 255, 0.075),
          rgba(255, 255, 255, 0.04)
        );
      }

      .works-video {
        position: relative;
        width: 100%;
        background: rgba(255, 255, 255, 0.03);
      }

      .works-video.full-video {
        padding-top: 56.25%;
      }

      .works-video iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        border: 0;
      }

      .works-body {
        padding: 18px 18px 20px;
      }

      .works-body h3 {
        margin: 0 0 8px;
        font-size: 18px;
      }

      .works-body p {
        margin: 0;
        color: var(--muted);
        font-size: 14px;
        line-height: 1.7;
      }

      .works-card.short-card .works-body {
        padding: 14px 16px 18px;
      }

      .works-card.short-card .works-body h3 {
        font-size: 16px;
        line-height: 1.5;
        margin: 0 0 6px;
      }

      .works-card.short-card .works-body p {
        font-size: 13px;
        line-height: 1.6;
      }

      .short-thumb-link {
        position: relative;
        display: block;
        width: 100%;
        aspect-ratio: 9 / 16;
        background: #000;
        overflow: hidden;
      }

      .short-thumb-image {
        width: 100%;
        height: 100%;
        object-fit: cover;
        display: block;
        background: #000;
      }

      .short-play-badge {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        width: 74px;
        height: 52px;
        border-radius: 18px;
        background: rgba(255, 0, 0, 0.92);
        box-shadow: 0 10px 24px rgba(0, 0, 0, 0.32);
      }

      .short-play-badge::before {
        content: "";
        position: absolute;
        left: 30px;
        top: 16px;
        width: 0;
        height: 0;
        border-top: 10px solid transparent;
        border-bottom: 10px solid transparent;
        border-left: 16px solid #fff;
      }

      .cta {
        padding: 32px;
        border-radius: 30px;
        background:
          radial-gradient(circle at 100% 0%, rgba(255, 255, 255, 0.08), transparent 32%),
          linear-gradient(
            180deg,
            rgba(255, 255, 255, 0.07),
            rgba(255, 255, 255, 0.04)
          );
        border: 1px solid rgba(255, 255, 255, 0.1);
      }

      .cta:hover {
        transform: translateY(-4px);
      }

      .cta p {
        margin: 0;
        color: var(--muted);
      }

      .cta-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 18px;
      }

      .template-card {
        margin-top: 18px;
      }

      .template-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        flex-wrap: wrap;
      }

      .template-box {
        margin-top: 12px;
        padding: 18px;
        border-radius: 20px;
        background: rgba(255, 255, 255, 0.03);
        border: 1px solid var(--line);
        color: var(--muted);
        white-space: pre-wrap;
      }

      .links {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
      }

      .mini-link {
        display: inline-flex;
        align-items: center;
        min-height: 42px;
        padding: 0 16px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid var(--line);
        color: var(--muted);
        transition: transform 0.25s ease, background 0.25s ease, color 0.25s ease;
      }

      .mini-link:hover {
        color: var(--text);
        background: rgba(255, 255, 255, 0.07);
        transform: translateY(-2px);
      }

      .request-form {
        display: grid;
        gap: 18px;
        margin-top: 18px;
      }

      .form-grid {
        display: grid;
        grid-template-columns: repeat(2, minmax(0, 1fr));
        gap: 16px;
      }

      .form-group {
        display: grid;
        gap: 8px;
      }

      .full-width {
        grid-column: 1 / -1;
      }

      .form-group label {
        font-size: 14px;
        color: var(--text);
        font-weight: 600;
      }

      .form-group input,
      .form-group select,
      .form-group textarea {
        width: 100%;
        padding: 14px 16px;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.04);
        color: var(--text);
        font: inherit;
        outline: none;
      }

      .form-group select {
        appearance: none;
        -webkit-appearance: none;
        -moz-appearance: none;
        background:
          linear-gradient(45deg, transparent 50%, var(--muted) 50%),
          linear-gradient(135deg, var(--muted) 50%, transparent 50%),
          rgba(255, 255, 255, 0.04);
        background-position:
          calc(100% - 20px) calc(50% - 3px),
          calc(100% - 14px) calc(50% - 3px),
          0 0;
        background-size: 6px 6px, 6px 6px, 100% 100%;
        background-repeat: no-repeat;
        padding-right: 42px;
      }

      .form-group select option {
        background: #1b1c1f;
        color: #f3f3f4;
      }

      .form-group input:focus,
      .form-group select:focus,
      .form-group textarea:focus {
        border-color: rgba(255,255,255,0.22);
        background-color: rgba(255,255,255,0.06);
      }

      .form-group input::placeholder,
      .form-group textarea::placeholder {
        color: var(--muted);
      }

      .form-group textarea {
        resize: vertical;
        min-height: 140px;
      }

      .form-note {
        margin: 0;
        font-size: 13px;
        color: var(--muted);
        line-height: 1.7;
      }

      .form-status {
        display: none;
        margin-top: 18px;
        padding: 16px 18px;
        border-radius: 18px;
        border: 1px solid transparent;
        font-size: 14px;
        line-height: 1.8;
      }

      .form-status.is-visible {
        display: block;
      }

      .form-status.success {
        background: var(--success-bg);
        border-color: var(--success-line);
        color: var(--text);
      }

      .form-status.error {
        background: var(--error-bg);
        border-color: var(--error-line);
        color: var(--text);
      }

      .footer {
        padding: 40px 0 70px;
        color: var(--muted);
        font-size: 14px;
      }

      .footer p {
        margin: 0 0 10px;
      }

      .footer-links {
        display: flex;
        flex-wrap: wrap;
        gap: 12px 18px;
        align-items: center;
      }

      .footer-links a {
        color: var(--muted);
        border-bottom: 1px solid rgba(255, 255, 255, 0.16);
        padding-bottom: 2px;
        transition: color 0.2s ease, border-bottom-color 0.2s ease;
      }

      .footer-links a:hover {
        color: var(--text);
        border-bottom-color: rgba(255, 255, 255, 0.45);
      }

      .divider {
        height: 1px;
        background: rgba(255, 255, 255, 0.06);
        margin-bottom: 18px;
      }

      .reveal {
        opacity: 0;
        transform: translateY(42px) scale(0.985);
        transition:
          opacity 1s cubic-bezier(0.22, 1, 0.36, 1),
          transform 1s cubic-bezier(0.22, 1, 0.36, 1);
        will-change: opacity, transform;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0) scale(1);
      }

      .delay-a {
        transition-delay: 0.05s;
      }

      .delay-b {
        transition-delay: 0.18s;
      }

      .delay-c {
        transition-delay: 0.32s;
      }

      @media (max-width: 900px) {
        .grid-2,
        .grid-3,
        .discount-grid,
        .terms-grid,
        .form-grid {
          grid-template-columns: 1fr;
        }

        .header-inner {
          min-height: auto;
          padding: 14px 0;
          flex-direction: column;
          align-items: flex-start;
        }

        .header-nav {
          width: 100%;
          gap: 10px 14px;
        }

        .header-nav a {
          font-size: 13px;
        }

        .hero {
          padding: 72px 0 48px;
        }

        .hero-title {
          font-size: clamp(22px, 6vw, 34px);
          line-height: 1.1;
          letter-spacing: -0.05em;
          margin: 18px 0 14px;
          white-space: nowrap;
        }

        .hero-title-wrap::after {
          left: 4%;
          right: 4%;
          height: 20px;
          bottom: -4px;
        }

        .hero-lead {
          font-size: 15px;
          line-height: 1.7;
        }

        .hero-actions,
        .section-cta,
        .cta-actions {
          flex-direction: column;
          align-items: stretch;
        }

        .button {
          width: 100%;
          min-height: 48px;
        }

        section {
          padding: 64px 0;
        }

        .section-title {
          font-size: clamp(24px, 8vw, 34px);
          line-height: 1.2;
        }

        .section-lead {
          font-size: 14px;
          line-height: 1.7;
        }

        .card,
        .price-card,
        .cta,
        .discount-card,
        .terms-card,
        .payment-card,
        .recommend-line,
        .preview-card,
        .delivery-card {
          padding: 20px;
          border-radius: 22px;
        }

        .price-value,
        .discount-card .discount-value {
          font-size: 28px;
        }

        .template-header {
          align-items: stretch;
        }

        .template-header .button {
          width: 100%;
        }

        .links {
          display: grid;
          grid-template-columns: 1fr 1fr;
          gap: 10px;
        }

        .mini-link {
          justify-content: center;
          width: 100%;
          min-height: 40px;
        }

        .works-scroll.full-scroll {
          grid-auto-columns: 88vw;
        }

        .works-scroll.short-scroll {
          grid-auto-columns: min(220px, 78vw);
        }

        .works-controls {
          justify-content: flex-start;
        }

        .full-width {
          grid-column: auto;
        }
      }

      @media (max-width: 480px) {
        .container {
          width: min(var(--max-width), calc(100% - 20px));
        }

        .hero {
          padding: 64px 0 42px;
        }

        .hero-title {
