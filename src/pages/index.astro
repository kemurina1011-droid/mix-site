    <script src="https://js.usebasin.com/v2.11.1.min.js" defer></script>

    <script>
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        {
          threshold: 0.14,
        }
      );

      document.querySelectorAll(".reveal").forEach((el) => {
        observer.observe(el);
      });

      const copyButton = document.getElementById("copyTemplateButton");
      const templateText = document.getElementById("xTemplateText");
      const copyMessage = document.getElementById("copyTemplateMessage");

      if (copyButton && templateText && copyMessage) {
        copyButton.addEventListener("click", async () => {
          try {
            await navigator.clipboard.writeText(templateText.innerText);
            copyButton.textContent = "コピーしました";
            copyMessage.textContent =
              "テンプレートをコピーしました。DMにそのまま貼り付けできます。";

            setTimeout(() => {
              copyButton.textContent = "テンプレートをコピー";
              copyMessage.textContent =
                "コピーしてそのままDMでお送りください。";
            }, 2000);
          } catch (error) {
            copyMessage.textContent =
              "コピーに失敗しました。手動でコピーしてください。";
          }
        });
      }

      const worksTabs = document.querySelectorAll("[data-works-tab]");
      const worksPanels = document.querySelectorAll("[data-works-panel]");

      worksTabs.forEach((tab) => {
        tab.addEventListener("click", () => {
          const target = tab.dataset.worksTab;

          worksTabs.forEach((item) => {
            item.classList.remove("is-active");
            item.setAttribute("aria-selected", "false");
          });

          worksPanels.forEach((panel) => {
            panel.classList.remove("is-active");
          });

          tab.classList.add("is-active");
          tab.setAttribute("aria-selected", "true");

          const activePanel = document.querySelector(`[data-works-panel="${target}"]`);
          if (activePanel) {
            activePanel.classList.add("is-active");
          }
        });
      });

      const shuffleWorksCards = (scrollId) => {
        const container = document.getElementById(scrollId);
        if (!container) return;

        const cards = Array.from(container.querySelectorAll(".works-card"));

        for (let i = cards.length - 1; i > 0; i--) {
          const j = Math.floor(Math.random() * (i + 1));
          [cards[i], cards[j]] = [cards[j], cards[i]];
        }

        cards.forEach((card) => container.appendChild(card));
      };

      shuffleWorksCards("worksScrollFull");
      shuffleWorksCards("worksScrollShort");

      const setupScrollButtons = (scrollId, prevId, nextId) => {
        const scrollElement = document.getElementById(scrollId);
        const prevButton = document.getElementById(prevId);
        const nextButton = document.getElementById(nextId);

        if (!scrollElement || !prevButton || !nextButton) return;

        const getScrollAmount = () => {
          const firstCard = scrollElement.querySelector(".works-card");
          if (!firstCard) return 420;
          const cardWidth = firstCard.getBoundingClientRect().width;
          return cardWidth + 16;
        };

        prevButton.addEventListener("click", () => {
          scrollElement.scrollBy({
            left: -getScrollAmount(),
            behavior: "smooth",
          });
        });

        nextButton.addEventListener("click", () => {
          scrollElement.scrollBy({
            left: getScrollAmount(),
            behavior: "smooth",
          });
        });
      };

      setupScrollButtons("worksScrollFull", "worksPrevButton", "worksNextButton");
      setupScrollButtons("worksScrollShort", "worksPrevButtonShort", "worksNextButtonShort");

      const basinSuccess = document.getElementById("mix-form-success");
      const basinError = document.getElementById("mix-form-error");

      if (basinSuccess) {
        const successObserver = new MutationObserver(() => {
          if (basinSuccess.style.display !== "none") {
            basinSuccess.classList.add("is-visible");
            basinError?.classList.remove("is-visible");
          }
        });
        successObserver.observe(basinSuccess, {
          attributes: true,
          attributeFilter: ["style", "class"],
        });
      }

      if (basinError) {
        const errorObserver = new MutationObserver(() => {
          if (basinError.style.display !== "none") {
            basinError.classList.add("is-visible");
            basinSuccess?.classList.remove("is-visible");
          }
        });
        errorObserver.observe(basinError, {
          attributes: true,
          attributeFilter: ["style", "class"],
        });
      }
    </script>
